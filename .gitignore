packages/db/data/test-spec-table.csv

# CSCJ — datos con PII de alumnos (nombres/RUTs). Nunca versionar (Ley 19.628).
# Solo se versionan los scripts; sus salidas de datos quedan fuera de git.
# (La planilla de digitación se genera en ../docs, fuera de este repo.)
scripts/cscj/**/*.xlsx
scripts/cscj/**/*.csv
scripts/cscj/**/*.json
