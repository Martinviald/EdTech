{
  "name": "@soe/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:provision-roles": "tsx src/provision-cloud-roles.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed/index.ts",
    "db:seed:e2e": "tsx src/seed/e2e-testing.ts",
    "db:seed:benchmark": "tsx src/seed/benchmark-demo.ts",
    "db:seed:taxonomy": "tsx src/seed/taxonomy-real.ts",
    "db:import:instruments": "tsx src/seed/import-instruments.ts",
    "db:import:item-tags": "tsx src/seed/import-item-tags.ts",
    "db:reset": "tsx src/reset-schema.ts && tsx src/migrate.ts && tsx src/seed/index.ts && tsx src/seed/e2e-testing.ts && tsx src/seed/benchmark-demo.ts",
    "lint": "echo 'lint: db ok'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@soe/types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
