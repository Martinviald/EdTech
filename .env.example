# Database
# DATABASE_URL: usada por la API en runtime. Para que el RLS multi-tenant filtre,
# en entornos con RLS debe apuntar a un rol NO privilegiado (ej. soe_app, sin
# BYPASSRLS). Ver packages/db/sql/roles.sql.
DATABASE_URL=postgresql://user:password@localhost:5432/soe_dev
# DATABASE_ADMIN_URL: usada SOLO por migrate/seed/reset. Rol privilegiado
# (owner/superuser, bypassa RLS) para DDL y carga de datos sin contexto de org.
# Si se omite, migrate/seed caen a DATABASE_URL (en dev suele ser superuser).
DATABASE_ADMIN_URL=postgresql://user:password@localhost:5432/soe_dev

# NextAuth
NEXTAUTH_SECRET=replace-me-with-a-secure-random-string
NEXTAUTH_URL=http://localhost:3000
# AUTH_SECRET: usado por el API (NestJS) para validar el JWE de NextAuth.
# DEBE ser idéntico a NEXTAUTH_SECRET, o el API no podrá descifrar el token.
AUTH_SECRET=replace-me-with-a-secure-random-string

# AUTH_MODE controla el flujo de autenticación.
#   - 'sso'  → flujo real con Google Workspace / Microsoft 365 (requiere credenciales abajo)
#   - 'mock' → dropdown de usuarios del seed, solo para desarrollo local (NO usar en prod)
AUTH_MODE=sso

# SSO Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# API
API_PORT=4000
API_URL=http://localhost:4000
# Secreto compartido entre Next.js y NestJS para endpoints @Public() internos.
# Úsalo para proteger rutas que Next.js llama sin Bearer token (ej: auth callbacks).
INTERNAL_API_SECRET=replace-me-with-a-secure-random-string

# ── Integración LLM (etiquetado IA de ítems, H3.11) ──
# Proveedor activo: anthropic | gemini | openai | deepseek (default: gemini).
# Cambiar de proveedor/modelo sin tocar código se hace con estas dos variables;
# si se omiten, se usan los valores de apps/api/src/llm/llm.constants.ts.
LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash

# API keys por proveedor (solo se necesita la del proveedor activo)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
