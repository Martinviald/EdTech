{
  "name": "edtech",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma EdTech con IA para colegios chilenos",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "db:seed:e2e": "pnpm --filter @soe/db db:seed:e2e",
    "db:seed:dev": "pnpm --filter @soe/db db:seed:dev",
    "db:migrate:dev": "pnpm --filter @soe/db db:migrate:dev",
    "db:reset": "pnpm --filter @soe/db db:reset",
    "db:studio": "turbo run db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
